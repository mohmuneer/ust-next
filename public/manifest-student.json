{
  "name": "UST بوابة الطالب",
  "short_name": "UST طالب",
  "description": "جامعة العلوم والتكنولوجيا - بوابة الطالب الإلكترونية",
  "start_url": "/student/dashboard",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#038ed3",
  "theme_color": "#038ed3",
  "orientation": "any",
  "dir": "rtl",
  "lang": "ar",
  "scope": "/student/",
  "id": "/student/",
  "categories": ["education", "productivity"],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "shortcuts": [
    {
      "name": "الجدول الدراسي",
      "short_name": "الجدول",
      "url": "/student/schedule",
      "icons": [{ "src": "/ust-logo.png", "sizes": "96x96" }]
    },
    {
      "name": "الدرجات",
      "short_name": "الدرجات",
      "url": "/student/grades",
      "icons": [{ "src": "/ust-logo.png", "sizes": "96x96" }]
    },
    {
      "name": "الرسائل",
      "short_name": "الرسائل",
      "url": "/student/messages",
      "icons": [{ "src": "/ust-logo.png", "sizes": "96x96" }]
    },
    {
      "name": "الامتحانات",
      "short_name": "الامتحانات",
      "url": "/student/exams",
      "icons": [{ "src": "/ust-logo.png", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/student/dashboard",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link"
    }
  },
  "icons": [
    {
      "src": "/ust-logo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/ust-logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/ust-logo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/ust-logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
